# State files — contain sensitive data, never commit
*.tfstate
*.tfstate.*

# Real vars files — gitignored, use terraform.tfvars.example as template
terraform.tfvars

# Terraform working directories
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
